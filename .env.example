# Telegram bot token from @BotFather. Required.
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Telegram user ID of the super-administrator (fallback default below).
ADMIN_ID=8188875246

# Comma-separated Telegram user IDs allowed to call /api/admin/* endpoints
# (the BilimBook admin panel). Defaults to just ADMIN_ID if unset.
# ADMIN_USER_IDS=8188875246,123456789

# Public URL of the WebApp frontend (GitHub Pages, etc.) opened by the
# "Открыть курс" button.
WEBAPP_URL=https://kslmvv.github.io/bos-course/

# Supabase/PostgreSQL connection string (Session/Transaction pooler URI).
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# Groq API key. Required. Powers Whisper transcription in the automated
# lesson-ingestion pipeline (lesson_pipeline.py) — an admin posts a YouTube
# link to the bot to trigger it.
GROQ_API_KEY=gsk_ExampleKeyReplaceMe

# Cerebras API key. Required. Powers the LLM topic-grouping step of the same
# pipeline (gpt-oss-120b, OpenAI-compatible endpoint) — separate from Groq
# so a long transcript's token usage doesn't compete with Whisper's quota.
CEREBRAS_API_KEY=csk-ExampleKeyReplaceMe

# Optional: max age (seconds) of Telegram WebApp initData before rejection.
# INIT_DATA_MAX_AGE=86400

# Provided automatically by Railway; only needed for local runs.
# PORT=8080
