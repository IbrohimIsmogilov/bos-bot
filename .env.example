# Telegram bot token from @BotFather. Required.
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Telegram user ID of the super-administrator (fallback default below).
ADMIN_ID=8188875246

# Public URL of the WebApp frontend (GitHub Pages, etc.) opened by the
# "Открыть курс" button.
WEBAPP_URL=https://kslmvv.github.io/bos-course/

# Supabase/PostgreSQL connection string (Session/Transaction pooler URI).
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# Optional: max age (seconds) of Telegram WebApp initData before rejection.
# INIT_DATA_MAX_AGE=86400

# Provided automatically by Railway; only needed for local runs.
# PORT=8080
